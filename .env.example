# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

BEDROCK_UPLOAD_ACCESS_KEY_ID=your_upload_access_key_here
BEDROCK_UPLOAD_SECRET_ACCESS_KEY=your_upload_secret_key_here

# RAG Configuration
KNOWLEDGE_BASE_ID=your_knowledge_base_id_here
MODEL_ID=amazon.nova-micro-v1:0
MAX_RESULTS=5

# TTS Configuration
ENABLE_TTS=true
TTS_VOICE_ID=Joanna
TTS_ENGINE=neural
TTS_LANGUAGE_CODE=en-US
