{
  "name": "miro-student",
  "version": "1.0.0",
  "description": "Miro Student Learning Companion - Baymax-inspired RAG interface",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:pi": "electron-builder --linux --armv7l"
  },
  "keywords": ["electron", "education", "rag", "ai", "baymax"],
  "author": "Miro Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.miro.student",
    "productName": "Miro Student",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Education"
    }
  }
}
